{
  "name": "contest-platform-backend",
  "version": "1.0.0",
  "description": "Coding Contest Platform - Phase 1 Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
